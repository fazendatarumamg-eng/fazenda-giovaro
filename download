// ─── Hooks ───────────────────────────────────────────────────────────────────
function useDB(key, defaultVal) {
  const [data, setData] = useState(defaultVal);
  const [loaded, setLoaded] = useState(false);

  useEffect(() => {
    DB.get(key).then(val => {
      if (val !== null) setData(val);
      setLoaded(true);
    });
  }, [key]);

  const save = useCallback((val) => {
    setData(prev => {
      const next = typeof val === "function" ? val(prev) : val;
      DB.set(key, next);
      return next;
    });
  }, [key]);

  return [data, save, loaded];
}

// ─── Dashboard ───────────────────────────────────────────────────────────────
function Dashboard({ animais, reproducoes, partos, perdas, onNavigate }) {
  const ativos = animais.filter(a => a.status === "Ativo").length;
  const gestantes = reproducoes.filter(r => r.status === "Confirmada" && !partos.find(p => p.reproducao_id === r.id) && !(perdas||[]).find(pd => pd.reproducao_id === r.id)).length;
  const alertasVet = (perdas || []).filter(p => p.vet && !p.vet_resolvido);

  const hoje = new Date();
  const alertas = reproducoes.filter(r => {
    if (r.status !== "Confirmada") return false;
    if (partos.find(p => p.reproducao_id === r.id)) return false;
    if (!r.previsao_parto) return false;
    const diff = (new Date(r.previsao_parto + "T12:00:00") - hoje) / 86400000;
    return diff >= 0 && diff <= 30;
  });

  const recentes = partos.slice(-3).reverse();

  return (
    <div>
      <div className="stat-row">
        <div className="stat">
          <div className="stat-num">{ativos}</div>
          <div className="stat-label">Animais ativos</div>
        </div>
        <div className="stat">
          <div className="stat-num">{gestantes}</div>
          <div className="stat-label">Gestantes</div>
        </div>
        <div className="stat">
          <div className="stat-num">{partos.length}</div>
          <div className="stat-label">Partos reg.</div>
        </div>
      </div>

      {alertasVet.length > 0 && (
        <div className="alert alert-warn" style={{ marginBottom: 4, cursor: "pointer" }} onClick={() => onNavigate("repro")}>
          <strong>🩺 {alertasVet.length} animal(is) aguardando veterinário</strong>
          {alertasVet.slice(0,3).map(p => {
            const a = animais.find(an => an.id === p.mae_id);
            return <span key={p.id} style={{ display: "block", fontSize: 12 }}>→ {a?.nome} — {p.tipo}</span>;
          })}
        </div>
      )}

      {alertas.length > 0 && (
        <>
          <p className="section-title"><span>⚠️ Partos próximos</span><small>próx. 30 dias</small></p>
          {alertas.map(r => {
            const animal = animais.find(a => a.id === r.animal_id);
            const diff = Math.ceil((new Date(r.previsao_parto + "T12:00:00") - hoje) / 86400000);
            return (
              <div key={r.id} className="alert alert-warn" onClick={() => onNavigate("repro")}>
                <strong>{animal?.nome || "Animal"} ({animal?.brinco})</strong>
                Previsão: {fmt(r.previsao_parto)} — <b>{diff} dia{diff !== 1 ? "s" : ""}</b>
              </div>
            );
          })}
        </>
      )}

      <p className="section-title"><span>Partos recentes</span></p>
      {recentes.length === 0 && <div className="empty"><div className="empty-icon">🐄</div><p>Nenhum parto registrado ainda</p></div>}
      {recentes.map(p => {
        const mae = animais.find(a => a.id === p.mae_id);
        const crias = (p.crias || []);
        return (
          <div key={p.id} className="card birth-card">
            <div className="card-header">
              <div>
                <div className="card-title">{mae?.nome || "—"}</div>
                <div className="card-sub">Parto em {fmt(p.data_parto)}</div>
              </div>
              <span className="badge badge-green">✓ Registrado</span>
            </div>
            <div style={{ display: "flex", gap: 8, flexWrap: "wrap" }}>
              {crias.map((c, i) => (
                <span key={i} className={`badge ${c.sexo === "F" ? "badge-earth" : "badge-gray"}`}>
                  {c.sexo === "F" ? "♀" : "♂"} {c.nome || "Cria"}
                </span>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  );
}

