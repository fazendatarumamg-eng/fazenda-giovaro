// ─── Reproducao List ──────────────────────────────────────────────────────────
function ReproducaoList({ animais, reproducoes, partos, perdas, onNew, onParto, onPerda, onSelect }) {
  const [tab, setTab] = useState("ativas");
  const PERDAS_STATUS = ["Aborto","Morte embrionária","Natimorto","Distócico"];

  const ativas = reproducoes.filter(r =>
    r.status === "Confirmada" &&
    !partos.find(p => p.reproducao_id === r.id) &&
    !PERDAS_STATUS.includes(r.status)
  );
  const historico = reproducoes.filter(r =>
    r.status !== "Confirmada" ||
    partos.find(p => p.reproducao_id === r.id) ||
    PERDAS_STATUS.includes(r.status)
  );

  const list = tab === "ativas" ? ativas : historico;
  const hoje = new Date();

  // Animais com alerta veterinário
  const alertasVet = (perdas || []).filter(p => p.vet && !p.vet_resolvido);

  return (
    <div>
      {alertasVet.length > 0 && (
        <div className="alert alert-warn" style={{ marginBottom: 14 }}>
          <strong>🩺 {alertasVet.length} animal(is) aguardando acompanhamento veterinário</strong>
          {alertasVet.map(p => {
            const a = animais.find(an => an.id === p.mae_id);
            return <span key={p.id} style={{ display: "block", fontSize: 12, marginTop: 2 }}>→ {a?.nome} — {p.tipo} em {fmt(p.data)}</span>;
          })}
        </div>
      )}

      <button className="btn btn-primary" style={{ marginBottom: 14 }} onClick={onNew}>
        <Icon name="plus" size={18} /> Registrar evento reprodutivo
      </button>
      <div className="tabs">
        <button className={`tab ${tab === "ativas" ? "active" : ""}`} onClick={() => setTab("ativas")}>Gestações ({ativas.length})</button>
        <button className={`tab ${tab === "hist" ? "active" : ""}`} onClick={() => setTab("hist")}>Histórico</button>
      </div>
      {list.length === 0 && <div className="empty"><div className="empty-icon">📋</div><p>Nenhum registro aqui</p></div>}
      {list.map(r => {
        const animal = animais.find(a => a.id === r.animal_id);
        const parto = partos.find(p => p.reproducao_id === r.id);
        const perda = (perdas || []).find(p => p.reproducao_id === r.id);
        let diasLabel = null;
        if (r.previsao_parto && !parto && !perda) {
          const diff = Math.ceil((new Date(r.previsao_parto + "T12:00:00") - hoje) / 86400000);
          diasLabel = diff >= 0 ? `${diff}d para parir` : `${Math.abs(diff)}d atrasada`;
        }
        return (
          <div key={r.id} className="card" style={{ cursor: "pointer", borderLeft: perda ? "3px solid var(--danger)" : undefined }} onClick={() => onSelect(r)}>
            <div className="card-header">
              <div>
                <div className="card-title">{animal?.nome || "—"}</div>
                <div className="card-sub">Brinco {animal?.brinco || "—"} · {r.atividade} em {fmt(r.data_evento)}</div>
              </div>
              <div style={{ display: "flex", flexDirection: "column", alignItems: "flex-end", gap: 4 }}>
                <span className={`badge ${statusBadge(perda ? perda.tipo : r.status)}`}>
                  {perda ? perda.tipo : r.status}
                </span>
                {diasLabel && <span className={`badge ${diasLabel.includes("atrasada") ? "badge-danger" : "badge-warn"}`}>{diasLabel}</span>}
                {perda?.vet && <span className="badge badge-warn">🩺 Vet</span>}
              </div>
            </div>
            {r.status === "Confirmada" && !parto && !perda && (
              <div style={{ display: "flex", gap: 8, marginTop: 8 }}>
                <button className="btn btn-ghost btn-sm" style={{ flex: 1 }} onClick={e => { e.stopPropagation(); onParto(r); }}>
                  🐄 Registrar parto
                </button>
                <button className="btn btn-danger btn-sm" style={{ flex: 1 }} onClick={e => { e.stopPropagation(); onPerda(r); }}>
                  ⚠ Registrar perda
                </button>
              </div>
            )}
            {parto && <div className="alert alert-green" style={{ marginTop: 8, marginBottom: 0 }}>Parto registrado em {fmt(parto.data_parto)}</div>}
            {perda && !parto && (
              <div className="alert alert-warn" style={{ marginTop: 8, marginBottom: 0 }}>
                {perda.tipo} em {fmt(perda.data)}{perda.causa ? ` · ${perda.causa}` : ""}
                {perda.tipo === "Distócico" && (
                  <button className="btn btn-ghost btn-sm" style={{ marginTop: 6, display: "block" }} onClick={e => { e.stopPropagation(); onParto(r); }}>
                    🐄 Registrar parto (distócico)
                  </button>
                )}
              </div>
            )}
          </div>
        );
      })}
    </div>
  );
}

// ─── Reproducao Form (wizard) ─────────────────────────────────────────────────
function ReproducaoForm({ animais, initial, onSave, onClose }) {
  const [step, setStep] = useState(0);
  const [form, setForm] = useState(initial || { animal_id: "", data_evento: today(), tipo: "Controle Reprodutivo", atividade: "IA", touro: "", status: "Pendente", previsao_parto: "", obs: "" });
  const set = (k, v) => setForm(f => {
    const next = { ...f, [k]: v };
    if (k === "data_evento" && next.status === "Confirmada") next.previsao_parto = addDays(v, 283);
    if (k === "status" && v === "Confirmada" && next.data_evento) next.previsao_parto = addDays(next.data_evento, 283);
    return next;
  });

  const femeas = animais.filter(a => a.sexo === "F" && a.status === "Ativo");
