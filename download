        <div className="section-title" style={{ marginTop: 8 }}>
          <span>🐮 Crias</span>
          <button className="btn btn-ghost btn-sm" onClick={addCria}><Icon name="plus" size={14} /> Adicionar cria</button>
        </div>

        {crias.map((c, i) => (
          <div key={i} className="card" style={{ marginBottom: 10 }}>
            <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 10 }}>
              <span style={{ fontWeight: 600, fontSize: 14 }}>Cria {i + 1}</span>
              {crias.length > 1 && <button className="btn btn-danger btn-sm" onClick={() => removeCria(i)}>✕ Remover</button>}
            </div>
            <div className="form-row">
              <div className="form-group"><label>Nome</label><input value={c.nome} onChange={e => setCria(i, "nome", e.target.value)} placeholder="Nome da cria" /></div>
              <div className="form-group"><label>Sexo</label>
                <select value={c.sexo} onChange={e => setCria(i, "sexo", e.target.value)}>
                  <option value="F">Fêmea</option><option value="M">Macho</option>
                </select>
              </div>
            </div>
            <div className="form-row">
              <div className="form-group"><label>Pelagem</label><input value={c.pelagem} onChange={e => setCria(i, "pelagem", e.target.value)} placeholder="Cor / pelagem" /></div>
              <div className="form-group"><label>Peso (kg)</label><input type="number" value={c.peso} onChange={e => setCria(i, "peso", e.target.value)} placeholder="0.0" /></div>
            </div>
          </div>
        ))}

        <div className="form-group"><label>Observações</label><textarea value={obs} onChange={e => setObs(e.target.value)} placeholder="Dificuldades, intercorrências…" /></div>

        <div className="alert alert-warn" style={{ marginBottom: 14 }}>
          <strong>📋 Retro-alimentação automática</strong>
          As crias serão cadastradas automaticamente no banco de animais após salvar.
        </div>

        <button className="btn btn-primary" onClick={() => onSave({ data_parto: data, crias, obs, mae_id: mae.id, reproducao_id: reproducao.id })}>
          <Icon name="check" size={18} /> Confirmar parto e cadastrar crias
        </button>
      </div>
    </div>
  );
}

// ─── Animal Detail ────────────────────────────────────────────────────────────
function AnimalDetail({ animal, reproducoes, partos, perdas, onClose, onEdit, onNewRepro }) {
  const historico = reproducoes.filter(r => r.animal_id === animal.id);
  const alertasVet = (perdas || []).filter(p => p.mae_id === animal.id && p.vet && !p.vet_resolvido);
  return (
    <div>
      <div className="sheet-handle" />
      <div className="sheet-header">
        <div>
          <h2 className="sheet-title">{animal.nome}</h2>
          <p style={{ fontSize: 12, color: "var(--muted)" }}>Brinco {animal.brinco || "—"} · {animal.raca || "—"}</p>
        </div>
        <button className="close-btn" onClick={onClose}>×</button>
      </div>
      <div className="sheet-body">
        <div style={{ display: "flex", gap: 8, flexWrap: "wrap", marginBottom: 14 }}>
          <span className={`badge ${animal.status === "Ativo" ? "badge-green" : "badge-gray"}`}>{animal.status}</span>
          <span className="badge badge-earth">{animal.categoria}</span>
          <span className="badge badge-gray">{animal.sexo === "F" ? "♀ Fêmea" : "♂ Macho"}</span>
          {alertasVet.length > 0 && <span className="badge badge-warn">🩺 Alerta vet.</span>}
        </div>

        {alertasVet.length > 0 && (
          <div className="alert alert-warn" style={{ marginBottom: 14 }}>
            <strong>Acompanhamento veterinário pendente</strong>
            {alertasVet.map(p => <span key={p.id} style={{ display: "block", fontSize: 12 }}>{p.tipo} em {fmt(p.data)}{p.causa ? ` · ${p.causa}` : ""}</span>)}
          </div>
        )}

        <div className="card">
          <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: "8px 16px", fontSize: 13 }}>
            {[["Nascimento", fmt(animal.nascimento)], ["Origem", animal.origem || "—"], ["Raça", animal.raca || "—"], ["Categoria", animal.categoria || "—"]].map(([l, v]) => (
              <div key={l}><span style={{ color: "var(--muted)", fontSize: 11, display: "block" }}>{l}</span><strong>{v}</strong></div>
            ))}
          </div>
          {animal.obs && <p style={{ marginTop: 10, fontSize: 13, color: "var(--muted)", borderTop: "1px solid var(--border)", paddingTop: 8 }}>{animal.obs}</p>}
        </div>

        <div style={{ display: "flex", gap: 10, marginBottom: 16 }}>
          <button className="btn btn-ghost btn-sm" style={{ flex: 1 }} onClick={onEdit}><Icon name="edit" size={14} /> Editar</button>
          {animal.sexo === "F" && animal.status === "Ativo" && (
            <button className="btn btn-secondary btn-sm" style={{ flex: 2 }} onClick={onNewRepro}>+ Evento reprodutivo</button>
          )}
        </div>

        {historico.length > 0 && (
          <>
            <p className="section-title"><span>Histórico reprodutivo</span></p>
            <div className="timeline">
              {historico.slice().reverse().map(r => {
                const p = partos.find(pt => pt.reproducao_id === r.id);
                const perda = (perdas || []).find(pd => pd.reproducao_id === r.id);
                const PERDAS_TIPOS = ["Aborto","Morte embrionária","Natimorto","Distócico"];
                return (
                  <div key={r.id} className="tl-item">
                    <div className={`tl-dot ${p ? "ok" : perda || r.status === "Falhou" ? "fail" : ""}`} />
                    <div className="tl-content">
                      <div className="tl-title">{r.atividade} — {r.touro || "—"}</div>
                      <div className="tl-date">{fmt(r.data_evento)} ·{" "}
                        <span className={`badge ${statusBadge(perda ? perda.tipo : r.status)}`} style={{ fontSize: 10 }}>
                          {perda ? perda.tipo : r.status}
                        </span>
                      </div>
                      {perda && (
                        <div style={{ fontSize: 12, color: "var(--danger)", marginTop: 4 }}>
                          {perda.tipo} em {fmt(perda.data)}{perda.causa ? ` · ${perda.causa}` : ""}
                          {perda.vet && <span className="badge badge-warn" style={{ marginLeft: 6, fontSize: 10 }}>🩺 Vet</span>}
                        </div>
                      )}
                      {r.previsao_parto && !p && !perda && <div style={{ fontSize: 12, color: "var(--muted)", marginTop: 4 }}>Previsão parto: {fmt(r.previsao_parto)}</div>}
                      {p && <div style={{ fontSize: 12, color: "var(--green)", marginTop: 4 }}>✓ Parto em {fmt(p.data_parto)} · {(p.crias || []).length} cria(s)</div>}
                    </div>
                  </div>
                );
              })}
            </div>
          </>
        )}
      </div>
    </div>
  );
}

// ─── App ──────────────────────────────────────────────────────────────────────
export default function App() {
  const [animais, setAnimais, animaisLoaded] = useDB("animais", ANIMAIS_DEMO);
  const [reproducoes, setReproducoes, reproLoaded] = useDB("reproducoes", REPRODUCOES_INIT);
  const [partos, setPartos, partosLoaded] = useDB("partos", PARTOS_INIT);
  const [perdas, setPerdas, perdasLoaded] = useDB("perdas", []);

  const loaded = animaisLoaded && reproLoaded && partosLoaded && perdasLoaded;

  const [tab, setTab] = useState("home");
  const [sheet, setSheet] = useState(null);

  const closeSheet = () => setSheet(null);

  // ── Handlers ──
  const saveAnimal = (form) => {
    if (form.id) {
      setAnimais(prev => prev.map(a => a.id === form.id ? form : a));
    } else {
      setAnimais(prev => [...prev, { ...form, id: uid() }]);
    }
    closeSheet();
  };

  const saveRepro = (form) => {
    if (form.id) {
      setReproducoes(prev => prev.map(r => r.id === form.id ? form : r));
    } else {
      setReproducoes(prev => [...prev, { ...form, id: uid() }]);
    }
    closeSheet();
  };

  const saveParto = (form) => {
    const partoId = uid();
    // Auto-create animal for each cria
    const novasCrias = (form.crias || []).map(c => {
      const mae = animais.find(a => a.id === form.mae_id);
      const repro = reproducoes.find(r => r.id === form.reproducao_id);
      const novaId = uid();
      const novoAnimal = {
        id: novaId,
        brinco: "",
        nome: c.nome || `Cria ${fmt(form.data_parto)}`,
        sexo: c.sexo,
        raca: mae?.raca || "",
        pelagem: c.pelagem,
        categoria: c.sexo === "F" ? "Bezerra" : "Bezerro",
        status: "Ativo",
        nascimento: form.data_parto,
        origem: "Nascimento",
        mae_id: form.mae_id,
        obs: `Nascida(o) de ${mae?.nome || "—"} · Sêmen/Touro: ${repro?.touro || "—"}`,
      };
      setAnimais(prev => [...prev, novoAnimal]);
      return { ...c, animal_id: novaId };
    });

    const novoParto = { ...form, id: partoId, crias: novasCrias };
    setPartos(prev => [...prev, novoParto]);
    closeSheet();
    setTab("home");
  };

  const savePerda = (form) => {
    const novaPerda = { ...form, id: uid() };
    setPerdas(prev => [...prev, novaPerda]);
    // Se natimorto: cadastra a cria com status Morto
    if (form.tipo === "Natimorto") {
      const mae = animais.find(a => a.id === form.mae_id);
      const repro = reproducoes.find(r => r.id === form.reproducao_id);
      const criaMorta = {
        id: uid(), brinco: "", nome: `Natimorto ${fmt(form.data)}`,
        sexo: "F", raca: mae?.raca || "", pelagem: "", categoria: "Bezerra",
        status: "Morto", nascimento: form.data, origem: "Nascimento",
        mae_id: form.mae_id,
        obs: `Natimorto · Mãe: ${mae?.nome || "—"} · Touro: ${repro?.touro || "—"}${form.causa ? " · " + form.causa : ""}`,
      };
      setAnimais(prev => [...prev, criaMorta]);
    }
    // Distócico: mantém gestação ativa para registrar o parto em seguida
    closeSheet();
    if (form.tipo !== "Distócico") setTab("home");
  };

  // ── Sheet renderer ──
  const renderSheet = () => {
    if (!sheet) return null;
    let content = null;

    if (sheet.type === "animal-form") {
      content = <AnimalForm initial={sheet.data} onSave={saveAnimal} onClose={closeSheet} />;
    } else if (sheet.type === "animal-detail") {
      content = <AnimalDetail
        animal={sheet.data}
        reproducoes={reproducoes}
        partos={partos}
        perdas={perdas}
        onClose={closeSheet}
        onEdit={() => setSheet({ type: "animal-form", data: sheet.data })}
        onNewRepro={() => setSheet({ type: "repro-form", data: { animal_id: sheet.data.id } })}
      />;
    } else if (sheet.type === "repro-form") {
      content = <ReproducaoForm animais={animais} initial={sheet.data} onSave={saveRepro} onClose={closeSheet} />;
    } else if (sheet.type === "parto-form") {
      const mae = animais.find(a => a.id === sheet.data.animal_id);
      content = <PartoForm mae={mae} reproducao={sheet.data} onSave={saveParto} onClose={closeSheet} />;
    } else if (sheet.type === "perda-form") {
      const mae = animais.find(a => a.id === sheet.data.animal_id);
      content = <PerdaForm mae={mae} reproducao={sheet.data} onSave={savePerda} onClose={closeSheet} />;
    } else if (sheet.type === "repro-detail") {
      const r = sheet.data;
      const animal = animais.find(a => a.id === r.animal_id);
      const parto = partos.find(p => p.reproducao_id === r.id);
      const perda = perdas.find(p => p.reproducao_id === r.id);
      content = (
        <div>
          <div className="sheet-handle" />
          <div className="sheet-header">
            <div><h2 className="sheet-title">{animal?.nome}</h2><p style={{ fontSize: 12, color: "var(--muted)" }}>{r.atividade} · {fmt(r.data_evento)}</p></div>
            <button className="close-btn" onClick={closeSheet}>×</button>
          </div>
          <div className="sheet-body">
            <div style={{ display: "flex", gap: 8, marginBottom: 14 }}>
              <span className={`badge ${statusBadge(perda ? perda.tipo : r.status)}`}>{perda ? perda.tipo : r.status}</span>
              {perda?.vet && <span className="badge badge-warn">🩺 Acomp. veterinário</span>}
            </div>
            <div className="card">
              {[["Animal", animal?.nome], ["Brinco", animal?.brinco || "—"], ["Atividade", r.atividade], ["Touro/Sêmen", r.touro || "—"], ["Data evento", fmt(r.data_evento)], ["Previsão parto", fmt(r.previsao_parto)]].map(([l, v]) => (
                <div key={l} style={{ display: "flex", justifyContent: "space-between", fontSize: 13, padding: "6px 0", borderBottom: "1px solid var(--border)" }}>
                  <span style={{ color: "var(--muted)" }}>{l}</span><strong>{v || "—"}</strong>
                </div>
              ))}
            </div>
            {perda && (
              <div className="alert alert-warn" style={{ marginTop: 12 }}>
                <strong>{perda.tipo} — {fmt(perda.data)}</strong>
                {perda.causa && <span style={{ display: "block" }}>Causa: {perda.causa}</span>}
                {perda.obs && <span style={{ display: "block", fontSize: 12 }}>{perda.obs}</span>}
              </div>
            )}
            {r.obs && !perda && <div className="alert alert-warn" style={{ marginTop: 12 }}>{r.obs}</div>}
            {r.status === "Confirmada" && !parto && !perda && (
              <div style={{ display: "flex", gap: 10, marginTop: 16 }}>
                <button className="btn btn-primary" style={{ flex: 2 }} onClick={() => setSheet({ type: "parto-form", data: r })}>
                  🐄 Registrar parto
                </button>
                <button className="btn btn-danger" style={{ flex: 1 }} onClick={() => setSheet({ type: "perda-form", data: r })}>
                  ⚠ Perda
                </button>
              </div>
            )}
            {perda?.tipo === "Distócico" && !parto && (
              <button className="btn btn-primary" style={{ marginTop: 12, width: "100%" }} onClick={() => setSheet({ type: "parto-form", data: r })}>
                🐄 Registrar parto (distócico)
              </button>
            )}
            {parto && (
              <div className="alert alert-green" style={{ marginTop: 16 }}>
                <strong>✓ Parto registrado — {fmt(parto.data_parto)}</strong>
                {(parto.crias || []).map((c, i) => <span key={i} className={`badge ${c.sexo === "F" ? "badge-earth" : "badge-gray"}`} style={{ marginRight: 4 }}>{c.sexo === "F" ? "♀" : "♂"} {c.nome}</span>)}
              </div>
            )}
            <button className="btn btn-ghost" style={{ marginTop: 10, width: "100%" }} onClick={() => setSheet({ type: "repro-form", data: r })}>
              <Icon name="edit" size={16} /> Editar registro
            </button>
          </div>
        </div>
      );
    }

    return (
      <div className="overlay" onClick={e => e.target === e.currentTarget && closeSheet()}>
        <div className="sheet">{content}</div>
      </div>
    );
  };

  return (
    <>
      <style>{css}</style>
      {!loaded ? (
        <div className="app" style={{ justifyContent: "center", alignItems: "center", display: "flex", flexDirection: "column", gap: 16, minHeight: "100vh" }}>
          <div style={{ fontSize: 48 }}>🐄</div>
          <p style={{ color: "var(--muted)" }}>Carregando dados…</p>
        </div>
      ) : (
      <div className="app">
        {/* Top bar */}
        <div className="topbar">
          <div>
            <h1>🐄 FazendaApp <span className="sub">Gestão de rebanho</span></h1>
          </div>
          {tab === "repro" && (
            <button className="topbar-btn" onClick={() => setSheet({ type: "repro-form", data: null })}>+ Evento</button>
          )}
          {tab === "animais" && (
            <button className="topbar-btn" onClick={() => setSheet({ type: "animal-form", data: null })}>+ Animal</button>
          )}
        </div>

        {/* Content */}
        <div className="scrollarea">
          {tab === "home" && (
            <>
              <p className="section-title"><span>Visão geral</span><small>{new Date().toLocaleDateString("pt-BR", { weekday: "long", day: "numeric", month: "long" })}</small></p>
              <Dashboard animais={animais} reproducoes={reproducoes} partos={partos} perdas={perdas} onNavigate={setTab} />
            </>
          )}
          {tab === "animais" && (
            <AnimalList
              animais={animais}
              onSelect={a => setSheet({ type: "animal-detail", data: a })}
              onNew={() => setSheet({ type: "animal-form", data: null })}
            />
          )}
          {tab === "repro" && (
            <ReproducaoList
              animais={animais}
              reproducoes={reproducoes}
              partos={partos}
              perdas={perdas}
              onNew={() => setSheet({ type: "repro-form", data: null })}
              onParto={r => setSheet({ type: "parto-form", data: r })}
              onPerda={r => setSheet({ type: "perda-form", data: r })}
              onSelect={r => setSheet({ type: "repro-detail", data: r })}
            />
          )}
        </div>

        {/* Bottom nav */}
        <nav className="bottomnav">
          {[
            { id: "home", icon: "home", label: "Início" },
            { id: "animais", icon: "cow", label: "Animais" },
            { id: "repro", icon: "baby", label: "Reprodução" },
          ].map(n => (
            <button key={n.id} className={tab === n.id ? "active" : ""} onClick={() => setTab(n.id)}>
              <Icon name={n.icon} />
              {n.label}
            </button>
          ))}
        </nav>

        {/* Sheet overlay */}
        {renderSheet()}
      </div>
      )}
    </>
  );
}
