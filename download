                </select>
              </div>
              <div className="form-group"><label>Touro / Sêmen</label><input value={form.touro} onChange={e => set("touro", e.target.value)} placeholder="Nome ou código" /></div>
            </div>
            <div className="form-group"><label>Observações</label><textarea value={form.obs} onChange={e => set("obs", e.target.value)} placeholder="Anotações…" /></div>
            <div style={{ display: "flex", gap: 10 }}>
              <button className="btn btn-ghost" style={{ flex: 1 }} onClick={() => setStep(0)}>← Voltar</button>
              <button className="btn btn-primary" style={{ flex: 2 }} onClick={() => setStep(2)}>Próximo →</button>
            </div>
          </>
        )}

        {step === 2 && (
          <>
            <div className="form-group"><label>Status da prenhez</label>
              <select value={form.status} onChange={e => set("status", e.target.value)}>
                <option value="Pendente">Pendente (aguardar confirmação)</option>
                <option value="Confirmada">Confirmada</option>
                <option value="Falhou">Falhou / Vazia</option>
              </select>
            </div>
            {form.status === "Confirmada" && (
              <div className="form-group">
                <label>Previsão de parto</label>
                <input type="date" value={form.previsao_parto} onChange={e => set("previsao_parto", e.target.value)} />
                <p style={{ fontSize: 11, color: "var(--muted)", marginTop: 4 }}>Calculado automaticamente: 283 dias após o evento</p>
              </div>
            )}
            <div style={{ display: "flex", gap: 10 }}>
              <button className="btn btn-ghost" style={{ flex: 1 }} onClick={() => setStep(1)}>← Voltar</button>
              <button className="btn btn-primary" style={{ flex: 2 }} onClick={() => onSave(form)}>
                <Icon name="check" size={18} /> Salvar
              </button>
            </div>
          </>
        )}
      </div>
    </div>
  );
}

