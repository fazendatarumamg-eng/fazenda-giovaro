// ─── Badge helper ─────────────────────────────────────────────────────────────
function statusBadge(status) {
  if (status === "Confirmada") return "badge-green";
  if (status === "Falhou") return "badge-danger";
  if (["Aborto","Morte embrionária","Natimorto","Distócico"].includes(status)) return "badge-danger";
  return "badge-warn";
}

